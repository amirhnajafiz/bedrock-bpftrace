/* read enter + exit */
tracepoint:syscalls:sys_enter_read
{{ filter }}
{
  @start[tid] = nsecs;
  @fd[tid] = args->fd;
  @count[tid] = args->count;
}

tracepoint:syscalls:sys_exit_read
{{ filter }}
{
  printf("%llu {pid=%d tid=%d proc=%s}{read}{fd=%d, count=%d, duration=%llu, ret=%d}\n", nsecs, pid, tid, comm, @fd[tid], @count[tid], nsecs - @start[tid], args->ret);
  delete(@start[tid]);
  delete(@fd[tid]);
  delete(@count[tid]);
}

