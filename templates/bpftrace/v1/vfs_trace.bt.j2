{{ begin_section }}

/* vfs read/readv and write/writev trace */
{% if capture_metadata %}
kfunc:vfs_read
{{ filter }}
{
  @start[tid] = nsecs;
  @fname[tid] = str(args->file->f_path.dentry->d_name.name);
  @count[tid] = args->count;
  @pos[tid] = args->pos;
}

kretfunc:vfs_read
{{ filter }}
{
  printf("%llu {pid=%d tid=%d proc=%s}{vfs_read}{fname=%s, count=%d, position=%lx, duration=%llu, ret=%d}\n", nsecs, pid, tid, comm, @fname[tid], @count[tid], @pos[tid], nsecs - @start[tid], retval);
  delete(@start[tid]);
  delete(@fname[tid]);
  delete(@count[tid]);
  delete(@pos[tid]);
}

