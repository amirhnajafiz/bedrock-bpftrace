{{ config_section }}
{{ begin_section }}

/* vfs read/readv and write/writev trace */
{% if capture_metadata %}
kfunc:vfs_read
{{ filter }}
{
  $file = args->file;
  $count = args->count;
  $pos = args->pos;
  printf("%llu {pid=%d tid=%d proc=%s}{EN vfs_read}{fname=%s, count=%d, position=%lx}\n", nsecs, pid, tid, comm, str($file->f_path.dentry->d_name.name), $count, $pos);
}

kfunc:vfs_write
{{ filter }}
{
  $file = args->file;
  $count = args->count;
  $pos = args->pos;
  printf("%llu {pid=%d tid=%d proc=%s}{EN vfs_write}{fname=%s, count=%d, position=%lx}\n", nsecs, pid, tid, comm, str($file->f_path.dentry->d_name.name), $count, $pos);
}

kfunc:vfs_readv
{{ filter }}
{
  $file = args->file;
  $count = args->vlen;
  $pos = args->pos;
  printf("%llu {pid=%d tid=%d proc=%s}{EN vfs_readv}{fname=%s, count=%d, position=%lx}\n", nsecs, pid, tid, comm, str($file->f_path.dentry->d_name.name), $count, $pos);
}

kfunc:vfs_writev
{{ filter }}
{
  $file = args->file;
  $count = args->vlen;
  $pos = args->pos;
  printf("%llu {pid=%d tid=%d proc=%s}{EN vfs_writev}{fname=%s, count=%d, position=%lx}\n", nsecs, pid, tid, comm, str($file->f_path.dentry->d_name.name), $count, $pos);
}
{% endif %}

kretfunc:vfs_read
{{ filter }}
{
  printf("%llu {pid=%d tid=%d proc=%s}{EX vfs_read}{ret=%d}\n", nsecs, pid, tid, comm, retval);
}

kretfunc:vfs_write
{{ filter }}
{
  printf("%llu {pid=%d tid=%d proc=%s}{EX vfs_write}{ret=%d}\n", nsecs, pid, tid, comm, retval);
}

kretfunc:vfs_readv
{{ filter }}
{
  printf("%llu {pid=%d tid=%d proc=%s}{EX vfs_readv}{ret=%d}\n", nsecs, pid, tid, comm, retval);
}

kretfunc:vfs_writev
{{ filter }}
{
  printf("%llu {pid=%d tid=%d proc=%s}{EX vfs_writev}{ret=%d}\n", nsecs, pid, tid, comm, retval);
}